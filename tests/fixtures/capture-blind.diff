 import { Order } from "./types.ts";
+import Redis from "ioredis";
 import { logger } from "./logger.ts";

+const stockCache = new Redis(process.env.REDIS_URL ?? "redis://localhost:6379");
+
 export async function reserveStock(order: Order): Promise<boolean> {
-  const available = await localInventory.check(order.sku, order.qty);
-  logger.info("reserveStock", { sku: order.sku, qty: order.qty, available });
-  return available >= order.qty;
+  const cached = await stockCache.get(`stock:${order.sku}`);
+  if (cached != null) {
+    logger.info("reserveStock cache hit", { sku: order.sku });
+    return Number(cached) >= order.qty;
+  }
+  const resp = await fetch(`http://inventory-service/stock/${order.sku}`, {
+    signal: AbortSignal.timeout(2000),
+  });
+  const { available } = (await resp.json()) as { available: number };
+  await stockCache.set(`stock:${order.sku}`, String(available), "EX", 300);
+  logger.info("reserveStock", { sku: order.sku, qty: order.qty, available });
+  return available >= order.qty;
 }
