# Delivery Radar — configuration (ADR-0007). Copy to `.env`; NEVER commit real keys.
# The radar's LLM backend is selected entirely by these env vars.

# --- which backend ---
# anthropic (default) | openrouter | vercel | openai-compat
RADAR_PROVIDER=anthropic

# model string (REQUIRED for gateways; format is provider-specific)
#   anthropic:   claude-sonnet-4-6
#   openrouter:  anthropic/claude-sonnet-4-6   |  deepseek/deepseek-chat
#   vercel:      anthropic/claude-sonnet-4-6   (provider/model slug)
RADAR_MODEL=

# structured output: json_object (default — widest support) | json_schema
# RADAR_JSON_MODE=json_object

# override the endpoint — REQUIRED for openai-compat; optional override for any preset
# RADAR_BASE_URL=

# --- keys ---
# Use your provider's NATIVE var; RADAR_API_KEY is the universal fallback for any provider.
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# AI_GATEWAY_API_KEY=        # Vercel AI Gateway
# RADAR_API_KEY=             # universal fallback; also the key for openai-compat

# --- copy-paste examples (pick one) ---
# Vercel AI Gateway:  RADAR_PROVIDER=vercel        RADAR_MODEL=anthropic/claude-sonnet-4-6   AI_GATEWAY_API_KEY=...
# OpenRouter:         RADAR_PROVIDER=openrouter     RADAR_MODEL=deepseek/deepseek-chat        OPENROUTER_API_KEY=...
# DeepSeek (direct):  RADAR_PROVIDER=openai-compat  RADAR_BASE_URL=https://api.deepseek.com   RADAR_MODEL=deepseek-v4-flash  RADAR_API_KEY=...
