# Delivery Radar — configuration template. Copy to `.envrc`; NEVER commit real keys.
#
# IMPORTANT: the CLI reads ONLY the process environment — it does NOT read this
# (or any) .envrc file. The runtime is a plain shell; no .envrc precondition is
# assumed (a CI pipeline has none). This file is a DEV CONVENIENCE: source it
# into your shell yourself, then run the CLI:
#
#     set -a; source .envrc; set +a
#     node dist/cli.js check --diff <diff>
#
# In CI/pipelines, inject these as real env vars / secrets instead.

# --- which backend ---
# anthropic (default) | openrouter | vercel | openai-compat
RADAR_PROVIDER=anthropic

# model string (REQUIRED for gateways; format is provider-specific)
#   anthropic:   claude-sonnet-4-6
#   openrouter:  anthropic/claude-sonnet-4-6   |  deepseek/deepseek-v4-pro
#   vercel:      anthropic/claude-sonnet-4-6   |  deepseek/deepseek-v4-pro
RADAR_MODEL=

# structured output: json_object (default — widest support) | json_schema
# RADAR_JSON_MODE=json_object

# override the endpoint — REQUIRED for openai-compat; optional override for any preset
# RADAR_BASE_URL=

# --- keys ---
# Use your provider's NATIVE var; RADAR_API_KEY is the universal fallback for any provider.
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# AI_GATEWAY_API_KEY=        # Vercel AI Gateway
# RADAR_API_KEY=             # universal fallback; also the key for openai-compat

# --- copy-paste examples (pick one) ---
# Vercel + DeepSeek:  RADAR_PROVIDER=vercel        RADAR_MODEL=deepseek/deepseek-v4-pro      AI_GATEWAY_API_KEY=...
# Vercel + Claude:    RADAR_PROVIDER=vercel        RADAR_MODEL=anthropic/claude-sonnet-4-6   AI_GATEWAY_API_KEY=...
# OpenRouter:         RADAR_PROVIDER=openrouter     RADAR_MODEL=deepseek/deepseek-v4-pro      OPENROUTER_API_KEY=...
# DeepSeek (direct):  RADAR_PROVIDER=openai-compat  RADAR_BASE_URL=https://api.deepseek.com   RADAR_MODEL=deepseek-v4-flash  RADAR_API_KEY=...
